{
  // Конфигурации запуска/отладки.
  // Сейчас доступен запуск текущего открытого файла.
  // Конфигурацию запуска веб-сервера добавим, когда появится код приложения.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python: текущий файл",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Flask: app.py",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/app.py",
      "console": "integratedTerminal",
      "env": {
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      }
    },
    {
      "name": "pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests", "-v"],
      "console": "integratedTerminal"
    }
  ]
}
