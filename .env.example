# Шаблон окружения. Скопируйте в .env (тот в .gitignore):  cp .env.example .env
# Значения по умолчанию совпадают с docker-compose.yml.

# psycopg 3 (драйвер psycopg) + SQLAlchemy 2.0
DATABASE_URL=postgresql+psycopg://corridor:corridor@localhost:5432/corridor

# Секрет Flask (понадобится на этапе 3). В проде — задать своё значение.
SECRET_KEY=dev-secret-change-me
